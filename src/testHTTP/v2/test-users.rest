@baseUrl = http://localhost:3002/api/v2/users
@json = Content-Type: application/json

### Read all users (MongoDB)
GET {{baseUrl}}

### Register user (MongoDB)
POST {{baseUrl}}/register
{{json}}

{
  "username": "Kangxi",
  "role": "admin",
  "email": "kangxi@example.com",
  "password": "qingdynasty1661"
}

### Login user (MongoDB)
# Copy token from response and paste into @token below if you want to test Bearer auth.
POST {{baseUrl}}/login
{{json}}

{
  "email": "kangxi@example.com",
  "password": "qingdynasty1661"
}

### Set token manually after login if your REST client does not keep cookies
@token = paste-your-jwt-token-here

### Get current user with Bearer token
GET {{baseUrl}}/me
Authorization: Bearer {{token}}

### Logout user
POST {{baseUrl}}/logout

### Update a user (MongoDB)
PUT {{baseUrl}}/6a0d6dde9f56e88888c06b7f
{{json}}

{
  "username": "Emperor Kangxi",
  "role": "user"
}

### Delete a user (MongoDB)
DELETE {{baseUrl}}/6a0d6dde9f56e88888c06b7f
