# Supabase / PostgreSQL - Users API (v2)
# Base: /api/v2/users/pg
#
# IDs in Supabase are UUIDs. Replace the placeholder below with a real one
# after running the POST request.
#
# @id = paste-a-real-uuid-here

### Read all users (Supabase)
GET http://localhost:3002/api/v2/users/pg

### Create a new user (Supabase)
POST http://localhost:3002/api/v2/users/pg
Content-Type: application/json

{
  "username": "Augustus",
  "role": "admin",
  "email": "octavian.augustus@imperium.rom",
  "password": "PaxRomana$27BC"
}

### Login user (Supabase)
POST http://localhost:3002/api/v2/users/pg/login
Content-Type: application/json

{
  "email": "octavian.augustus@imperium.rom",
  "password": "PaxRomana$27BC"
}

### Update a user (Supabase) - replace the UUID with a real id from GET response
PUT http://localhost:3002/api/v2/users/pg/paste-a-real-uuid-here
Content-Type: application/json

{
  "username": "Augustus Updated",
  "role": "admin"
}

### Delete a user (Supabase) - replace the UUID with a real id from GET response
DELETE http://localhost:3002/api/v2/users/pg/paste-a-real-uuid-here
